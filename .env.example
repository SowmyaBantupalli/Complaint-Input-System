# Environment Variables Configuration
# Copy this file to .env and fill in your actual values

# ===================================
# GOOGLE GEMINI API CONFIGURATION
# ===================================
# Get your free API key from: https://makersuite.google.com/app/apikey
# Free tier: 1500 requests per day
GEMINI_API_KEY=your_gemini_api_key_here

# ===================================
# DEPLOYMENT CONFIGURATION (Optional)
# ===================================
# For production deployments, you may want to restrict CORS origins
# Example: ALLOWED_ORIGINS=https://yourfrontend.com,https://app.yourdomain.com
# ALLOWED_ORIGINS=*

# ===================================
# NOTES
# ===================================
# 1. NEVER commit .env file to git (it's in .gitignore)
# 2. On Render, set GEMINI_API_KEY in Environment Variables section
# 3. The application will fall back to rule-based classification if GEMINI_API_KEY is not set
